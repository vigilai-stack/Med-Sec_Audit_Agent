{# skins/editorial.html.j2 — serif, print-first report layout.
   Masthead + numbered sections + ledger styling. Default skin for prd-review
   and user-story-review; also the print-optimized reference. #}
{% import "widgets.html.j2" as w %}
<!doctype html>
<html lang="en"{% if artifact.theme and artifact.theme.mode %} data-theme-mode="{{ artifact.theme.mode }}"{% endif %}>
<head>
  <meta charset="utf-8">
  <title>{{ artifact.title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
{{ theme_vars_css | safe }}
{{ base_css | safe }}
{{ skin_css | safe }}
@media print {
{{ print_css | safe }}
}
  </style>
</head>
<body class="skin-editorial">
  <main class="page">
    <header class="masthead">
      <p class="kicker">
        <span>{{ artifact.artifact_type | replace("-", " ") }}</span>
        <span class="right">schema v{{ artifact.schema_version }}{% if artifact.updated_at %} · {{ artifact.updated_at }}{% endif %}</span>
      </p>
      <h1>{{ artifact.title }}</h1>
      {% if artifact.subtitle %}<p class="deck">{{ artifact.subtitle }}</p>{% endif %}
      <div class="byline">
        {% if artifact.owner %}<span><b>Owner</b> {{ artifact.owner }}</span>{% endif %}
        {% if artifact.audience %}<span><b>Audience</b> {{ artifact.audience | join(", ") }}</span>{% endif %}
        {% if artifact.status %}<span class="status">{{ artifact.status }}</span>{% endif %}
      </div>
    </header>

    {% if artifact.summary %}
    <div class="abstract">
      <p class="label">Executive summary</p>
      <ul>
        {% for point in artifact.summary %}<li>{{ point }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% for section in sections %}
    <section id="{{ section.id }}" class="section section--{{ section.kind }}">
      <div class="sec-head">
        <span class="no">№ {{ "%02d" | format(loop.index) }}</span>
        <h2>{{ section.title }}</h2>
      </div>
      {{ w.body(section, frozen, frozen_svgs) }}
    </section>
    {% endfor %}

    {% if artifact.evidence %}
    <section id="evidence" class="evidence" aria-label="Evidence">
      <div class="sec-head">
        <span class="no">№ {{ "%02d" | format((sections | length) + 1) }}</span>
        <h2>Evidence</h2>
      </div>
      <ol>
        {% for item in artifact.evidence %}
        <li><a href="{{ item.href }}">{{ item.label }}</a> · <span class="ev-href">{{ item.href }}</span></li>
        {% endfor %}
      </ol>
    </section>
    {% endif %}

    <footer class="colophon">
      <span>Generated from canonical source</span>
      <span>{{ artifact.artifact_type }} · schema v{{ artifact.schema_version }}</span>
    </footer>
  </main>

  {% if not frozen %}
  <script type="module">
{{ mermaid_init | safe }}
  </script>
  {% endif %}
  <script>
{{ enhance_js | safe }}
  </script>
</body>
</html>
