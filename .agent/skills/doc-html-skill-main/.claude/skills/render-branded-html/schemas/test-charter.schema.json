{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/test-charter.schema.json",
  "title": "Test Charter Review (overlay)",
  "allOf": [{ "$ref": "review-artifact.schema.json" }],
  "properties": {
    "artifact_type": { "const": "test-charter" },
    "missions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "heuristics": { "type": "array", "items": { "type": "string" } },
    "coverage_boundaries": { "type": "array", "items": { "type": "string" } },
    "exit_criteria": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["missions"]
}
