#!/usr/bin/env bash
# Portable renderer wrapper: uses the project venv interpreter so the skill's
# render.py runs anywhere without per-dir dependency installs.
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
exec "$HERE/.venv/bin/python" \
  "$(cd "$(dirname "$0")" && pwd)/scripts/render.py" "$@"
