{# standard.html.j2 — single-file branded review document.
   Owns ALL chrome. Canonical source provides content only. #}
{%- macro render_table(section) -%}
<div class="table-wrap">
  <table class="data">
    <thead>
      <tr>
        {% for col in section.columns %}<th>{{ col }}</th>{% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in section.rows %}
      <tr>
        {% for cell in row %}<td>{{ "" if cell is none else cell }}</td>{% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{%- endmacro -%}
<!doctype html>
<html lang="en"{% if artifact.theme and artifact.theme.mode %} data-theme-mode="{{ artifact.theme.mode }}"{% endif %}>
<head>
  <meta charset="utf-8">
  <title>{{ artifact.title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
{{ theme_vars_css | safe }}
{{ base_css | safe }}
  </style>
</head>
<body>
  <main class="doc-shell">
    <header class="hero">
      <p class="eyebrow">{{ artifact.artifact_type | replace("-", " ") }}</p>
      <h1>{{ artifact.title }}</h1>
      {% if artifact.subtitle %}<p class="lead">{{ artifact.subtitle }}</p>{% endif %}
      <div class="meta-row">
        {% if artifact.status %}<span class="badge badge--status-{{ artifact.status }}">{{ artifact.status }}</span>{% endif %}
        {% if artifact.owner %}<span class="badge">Owner: {{ artifact.owner }}</span>{% endif %}
        {% if artifact.updated_at %}<span class="badge">Updated {{ artifact.updated_at }}</span>{% endif %}
        {% for a in artifact.audience or [] %}<span class="badge">{{ a }}</span>{% endfor %}
      </div>
    </header>

    {% if artifact.summary %}
    <section class="summary" aria-label="Executive summary">
      <h2>Summary</h2>
      <ul>
        {% for point in artifact.summary %}<li>{{ point }}</li>{% endfor %}
      </ul>
    </section>
    {% endif %}

    {% for section in artifact.sections or [] %}
    <section id="{{ section.id }}" class="section section--{{ section.kind }}">
      <h2>{{ section.title }}</h2>
      {% if section.kind == "prose" %}
        <div class="prose">{{ section.body }}</div>
      {% elif section.kind == "mermaid" %}
        <div class="mermaid-wrap">
          {% if frozen and frozen_svgs.get(section.id) %}
            {{ frozen_svgs.get(section.id) | safe }}
          {% else %}
            <pre class="mermaid">{{ section.source }}</pre>
          {% endif %}
        </div>
      {% elif section.kind == "table" %}
        {{ render_table(section) }}
      {% endif %}
    </section>
    {% endfor %}

    {% if artifact.evidence %}
    <section class="evidence" aria-label="Evidence">
      <h2>Evidence</h2>
      <ul>
        {% for item in artifact.evidence %}
        <li><a href="{{ item.href }}">{{ item.label }}</a> — <code>{{ item.href }}</code></li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

    <footer class="doc-footer">
      Generated from canonical source · {{ artifact.artifact_type }} · schema v{{ artifact.schema_version }}
    </footer>
  </main>

  {% if not frozen %}
  <script type="module">
{{ mermaid_init | safe }}
  </script>
  {% endif %}
</body>
</html>
