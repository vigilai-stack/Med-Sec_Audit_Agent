{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/review-artifact.schema.json",
  "title": "Review Artifact (base)",
  "description": "Shared base schema for all branded review documents. Artifact-specific schemas extend this via $ref + allOf.",
  "type": "object",
  "required": ["schema_version", "artifact_type", "title"],
  "comment": "Top-level additionalProperties is intentionally open so artifact overlays can add fields via allOf. Nested $defs stay strict.",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Schema major version. Bump only on breaking changes."
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "user-story-review",
        "architecture-review",
        "prd-review",
        "risk-analysis",
        "test-charter"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "audience": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["draft", "in-review", "approved", "archived"],
      "default": "draft"
    },
    "owner": { "type": "string" },
    "updated_at": { "type": "string", "format": "date" },
    "theme": { "$ref": "#/$defs/theme" },
    "summary": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Executive-summary bullet points."
    },
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/section" }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_link" }
    },
    "export": { "$ref": "#/$defs/export" }
  },
  "$defs": {
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["light", "dark", "auto"], "default": "auto" },
        "brand": { "type": "string", "default": "default" },
        "density": { "type": "string", "enum": ["compact", "comfortable", "spacious"], "default": "comfortable" }
      }
    },
    "evidence_link": {
      "type": "object",
      "required": ["label", "href"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "minLength": 1 }
      }
    },
    "export": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pdf": { "type": "boolean", "default": false },
        "freeze_diagrams": { "type": "boolean", "default": false }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "kind"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["prose", "mermaid", "table"] }
      },
      "oneOf": [
        {
          "title": "Prose section",
          "properties": {
            "kind": { "const": "prose" },
            "body": { "type": "string", "minLength": 1 }
          },
          "required": ["body"]
        },
        {
          "title": "Mermaid section",
          "properties": {
            "kind": { "const": "mermaid" },
            "diagram_type": {
              "type": "string",
              "enum": [
                "flowchart", "sequence", "er", "state", "journey",
                "timeline", "class", "gantt", "mindmap", "graph"
              ]
            },
            "source": { "type": "string", "minLength": 1 }
          },
          "required": ["diagram_type", "source"]
        },
        {
          "title": "Table section",
          "properties": {
            "kind": { "const": "table" },
            "columns": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "rows": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": ["string", "number", "boolean", "null"] }
              }
            }
          },
          "required": ["columns", "rows"]
        }
      ]
    }
  }
}
