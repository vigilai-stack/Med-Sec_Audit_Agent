{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/user-story-review.schema.json",
  "title": "User Story Review (overlay)",
  "allOf": [{ "$ref": "review-artifact.schema.json" }],
  "properties": {
    "artifact_type": { "const": "user-story-review" },
    "as_a": { "type": "string" },
    "i_want": { "type": "string" },
    "so_that": { "type": "string" },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "personas": { "type": "array", "items": { "type": "string" } },
    "journey_states": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } }
  },
  "required": ["acceptance_criteria"]
}
