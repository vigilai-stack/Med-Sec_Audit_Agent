{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/architecture-review.schema.json",
  "title": "Architecture Review (overlay)",
  "allOf": [{ "$ref": "review-artifact.schema.json" }],
  "properties": {
    "artifact_type": { "const": "architecture-review" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string" },
          "rationale": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "interfaces": { "type": "array", "items": { "type": "string" } },
    "deployment_context": { "type": "string" },
    "alternatives": { "type": "array", "items": { "type": "string" } }
  }
}
